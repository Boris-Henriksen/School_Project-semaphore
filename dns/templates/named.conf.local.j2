// Forward zone
zone "{{ zone_name }}" {
    type master;
    file "/etc/bind/zones/{{ zone_name }}.db";
    allow-transfer { 10.20.10.112; };  # Slave IP
};

{% for rz in reverse_zones %}
// Reverse zone
zone "{{ rz.zone_name }}" {
    type master;
    file "/etc/bind/zones/{{ rz.zone_name }}.db";
    allow-transfer { 10.20.10.112; };  # Slave IP
};
{% endfor %}

zone "heldigekartofler.local" {
    type forward;
    forward only;
    forwarders {
        10.10.10.8;
        10.10.10.7;
    };
};
